---
import Layout from "../layouts/Layout.astro";
import ScheduleComponent from "../components/Schedule/Schedule";
---
<Layout title="Schedule">
  <main id="checking" class="p-6">
    <h1>Checking access…</h1>
  </main>

  <main id="content" class="hidden">
    <h3>Schedule</h3>
    <div id="schedule-mount"></div>
  </main>

  <script>
    import { requireInvited } from "../lib/requireInvite";
    import { getIsEvening } from "../lib/getIsEvening";
    import { createElement } from "react";
    import { createRoot } from "react-dom/client";
    import ScheduleComponent from "../components/Schedule/Schedule";

    (async () => {
      const checking = document.getElementById("checking");
      const content = document.getElementById("content");

      const ctx = await requireInvited();
      if (!ctx) return;

      const isEvening = await getIsEvening(ctx.groupId);

      checking.classList.add("hidden");
      content.classList.remove("hidden");

      const mount = document.getElementById("schedule-mount");
      createRoot(mount).render(createElement(ScheduleComponent, { isEvening }));
    })();
  </script>
</Layout>

<style>
  .hidden { display: none; }
</style>
